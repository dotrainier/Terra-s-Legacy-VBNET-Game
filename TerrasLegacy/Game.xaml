        </Rectangle>
        <Rectangle Height="22" Width="229" Canvas.Left="1868" Canvas.Top="219" HorizontalAlignment="Left" VerticalAlignment="Top"  Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/tile1.png" Stretch="UniformToFill"/>
            </Rectangle.Fill>
        </Rectangle>


        <Rectangle Height="22" Width="315" Canvas.Left="812" Canvas.Top="161" Tag="platform" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/tile1.png" Stretch="UniformToFill"/>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle Height="22" Canvas.Top="161" Width="315" Tag="platformSetFoot" Canvas.Left="812" Stroke="Red" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="58" Width="555" Canvas.Top="296"  Canvas.Left="-675" Tag="platform" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor1.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <Image Source="pack://application:,,,/Assets/ui/gameOver.png" Canvas.Left="123" Canvas.Top="129" HorizontalAlignment="Left" VerticalAlignment="Center" Height="46" Width="320" x:Name="gameOverText"/>
        <Image Source="pack://application:,,,/Assets/ui/buttons/restartBtn.png" Canvas.Left="206" Canvas.Top="182" HorizontalAlignment="Center" Height="38" VerticalAlignment="Top" Stretch="None" MouseEnter="restartHover" MouseDown="RestartBtnClick" x:Name="restartBtn"/>
        <Rectangle Height="58" Width="676" Canvas.Top="294" Canvas.Left="2648" Tag="platform" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor4.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <ProgressBar Height="10" Width="80" Canvas.Left="32" Canvas.Top="49"  Value="300" Background="{x:Null}" OpacityMask="Black" Maximum="300" Foreground="#FF0D85B5" HorizontalAlignment="Center" VerticalAlignment="Top" x:Name="healthbar"/>
        <Label Content="HP" Canvas.Left="6" Canvas.Top="43" FontFamily="High Tower Text" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Content="300" Canvas.Left="59" Canvas.Top="43" FontFamily="Calibri" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="10" x:Name="hpNum"/>

    </Canvas>
</Window>
