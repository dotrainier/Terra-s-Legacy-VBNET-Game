                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/tile1.png" Stretch="UniformToFill"/>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle Height="22" Width="105" Canvas.Left="1444" Canvas.Top="165" HorizontalAlignment="Left" VerticalAlignment="Center" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/tile1.png" Stretch="UniformToFill"/>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle Height="22" Width="105" Canvas.Left="1662" Canvas.Top="194" HorizontalAlignment="Center" VerticalAlignment="Top" Tag="platform">
