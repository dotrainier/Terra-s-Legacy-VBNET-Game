        </Rectangle>

        <Rectangle Height="58" Width="661" HorizontalAlignment="Left" Canvas.Top="296" VerticalAlignment="Top" Canvas.Left="1322" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor3.png"/>
            </Rectangle.Fill>

        </Rectangle>


        <Rectangle Height="58" Width="676" HorizontalAlignment="Left" Canvas.Top="296" VerticalAlignment="Center" Canvas.Left="1983" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor4.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <Rectangle Height="49" Canvas.Top="301" Width="2648" Tag="platformSetFoot" Stroke="Red" HorizontalAlignment="Left" VerticalAlignment="Center" x:Name="floorPlatform"/>
        <Rectangle Height="22" Width="102" Canvas.Left="336" Canvas.Top="228" HorizontalAlignment="Center" VerticalAlignment="Top" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush Stretch="UniformToFill"  ImageSource="pack://application:,,,/Assets/Tiles/tile1.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <Rectangle Height="22" Width="102" Canvas.Left="613" Canvas.Top="208" HorizontalAlignment="Left" VerticalAlignment="Top" Tag="platform">
