<Window x:Class="Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TerrasLegacy"
        mc:Ignorable="d"
       Title="Terra's Legacy" Height="350" Width="530" KeyDown="windowKeyDown" KeyUp="windowKeyUp" Loaded="gameLoaded" WindowStartupLocation="CenterScreen">
    <Canvas VerticalAlignment="Bottom" Height="350" Focusable="True" x:Name="gameCanvas">

        <Rectangle Height="350" Width="2648" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="0" Canvas.Top="0" x:Name="bg">
            <Rectangle.Fill>
                <ImageBrush Stretch="UniformToFill" ImageSource="pack://application:,,,/Assets/bg/bg1.png"/>
            </Rectangle.Fill>

        </Rectangle>

        <Image  Canvas.Left="78" Canvas.Top="237" HorizontalAlignment="Left" VerticalAlignment="Center" x:Name="playerImage" Source="pack://application:,,,/Assets/characterActions/Terra/JumpRight/JumpRight4.png" OpacityMask="#FFF02929"/>
        <Rectangle Height="23" Canvas.Top="227" Width="102" Tag="platformSetFoot" Canvas.Left="335" HorizontalAlignment="Center" VerticalAlignment="Top" Stroke="Red"/>
        <Rectangle Height="23" Canvas.Top="207" Width="102" Tag="platformSetFoot" Canvas.Left="613" Stroke="Red" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="24" Canvas.Top="180" Width="105" Tag="platformSetFoot" Canvas.Left="1225" Stroke="Red" HorizontalAlignment="Center" VerticalAlignment="Top"/>
