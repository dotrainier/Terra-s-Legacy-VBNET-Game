        <Rectangle Height="20" Width="26" Canvas.Left="793" Canvas.Top="290" Tag="platform" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="4.431,0.819">
            <Rectangle.Fill>
                <ImageBrush Stretch="UniformToFill" ImageSource="pack://application:,,,/Assets/Tiles/stone1.png"/>
            </Rectangle.Fill>

        </Rectangle>

        <Rectangle Height="21" Width="26" Canvas.Left="595" Canvas.Top="285" Tag="platform" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/stone1.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <Rectangle Height="58" Width="781" HorizontalAlignment="Left" Canvas.Top="296" VerticalAlignment="Center"  Canvas.Left="-120" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor1.png"/>
            </Rectangle.Fill>

        </Rectangle>
        <Rectangle Height="58" Width="661" HorizontalAlignment="Center" Canvas.Top="296" VerticalAlignment="Top" Canvas.Left="661" Tag="platform">
            <Rectangle.Fill>
                <ImageBrush ImageSource="pack://application:,,,/Assets/Tiles/floor2.png"/>
