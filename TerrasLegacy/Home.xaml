<Window x:Class="Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:local="clr-namespace:TerrasLegacy"
        mc:Ignorable="d"
           Title="Home" Height="475" Width="580" Loaded="HomeLoaded" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/bg/cover2.png"/>
    </Window.Background>
    <Canvas VerticalAlignment="Bottom" Height="475">
        <Image Height="173" Width="252" Canvas.Left="307" Canvas.Top="119"  HorizontalAlignment="Center" VerticalAlignment="Top" x:Name="terraText" Source="pack://application:,,,/Assets/ui/TL.png" ></Image>
        <Image  Canvas.Left="391" Canvas.Top="280" HorizontalAlignment="Center" VerticalAlignment="Center" MouseEnter="startHover" MouseLeave="startNotHover" x:Name="startBtn" Stretch="None" Source="pack://application:,,,/Assets/ui/buttons/startBtn.png"/>
        <Image Canvas.Left="391" Canvas.Top="339"   x:Name="exitBtn"  MouseEnter="exitHover" MouseLeave="exitNotHover" Stretch="None" Source="pack://application:,,,/Assets/ui/buttons/exitBtn.png" />
    </Canvas>
</Window>
